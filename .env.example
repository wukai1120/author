# ============================================
#  Author App — 环境变量配置
# ============================================
#
#  📖 使用教程:
#
#  1. 复制本文件并重命名:
#     将 .env.example 复制一份，命名为 .env.local
#     （Windows: 复制粘贴后重命名; 命令行: copy .env.example .env.local）
#
#  2. 编辑 .env.local:
#     取消你需要的配置项的注释（删掉行首的 #），填入你自己的值
#     例如想用智谱AI，只需修改 API_KEY 那一行
#
#  3. 启动应用:
#     配置会自动生效，无需其他操作
#
#  ⚠️ 注意事项:
#     - 不要直接编辑 .env.example，它只是模板
#     - .env.local 已被 .gitignore 忽略，不会泄露你的 Key
#     - AI 配置统一由服务端环境变量控制（前端不再提供 API 配置）
#     - 只需配置你使用的那一个供应商，不需要全部填写
#
# ============================================


# ==================== 服务端口 ====================

# 自定义服务端口（默认 3000，被占用时自动递增查找）
# PORT=3000


# ==================== OpenAI 兼容 API ====================
# 适用于: 智谱AI / DeepSeek / SiliconFlow / 火山引擎 / Moonshot 等
# 所有兼容 OpenAI /v1/chat/completions 格式的供应商均可使用

# API_KEY=你的Key
# API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# API_MODEL=glm-4-flash

# 各供应商 Base URL 参考:
#   智谱AI:       https://open.bigmodel.cn/api/paas/v4
#   DeepSeek:     https://api.deepseek.com/v1
#   OpenAI:       https://api.openai.com/v1
#   SiliconFlow:  https://api.siliconflow.cn/v1
#   火山引擎:     https://ark.cn-beijing.volces.com/api/v3
#   Moonshot:     https://api.moonshot.cn/v1

# 各供应商推荐模型:
#   智谱AI:       glm-4-flash (免费) / glm-4-plus / glm-4-long / glm-4
#   DeepSeek:     deepseek-chat / deepseek-reasoner
#   SiliconFlow:  deepseek-ai/DeepSeek-V3 / Qwen/Qwen2.5-72B-Instruct
#   Moonshot:     moonshot-v1-8k / moonshot-v1-32k / moonshot-v1-128k

# 兼容旧版变量名（优先使用 API_KEY）
# ZHIPU_API_KEY=


# ==================== Google Gemini ====================
# 官网: https://aistudio.google.com

# GEMINI_API_KEY=你的Key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MODEL=gemini-2.0-flash

# 可选模型: gemini-2.0-flash-lite / gemini-1.5-flash / gemini-1.5-pro
# OpenAI 兼容模式也可用，将 Base URL 改为:
#   https://generativelanguage.googleapis.com/v1beta/openai
# 然后使用上方 API_KEY/API_BASE_URL/API_MODEL 配置即可


# ==================== Claude (Anthropic) ====================
# 官网: https://console.anthropic.com

# CLAUDE_API_KEY=你的Key
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_MODEL=claude-sonnet-4-20250514

# 可选模型: claude-3-7-sonnet-20250219 / claude-3-5-haiku-20241022


# ==================== OpenAI Responses API ====================
# 适用于 OpenAI /v1/responses 格式

# OPENAI_API_KEY=你的Key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 可选模型: gpt-4o / gpt-4-turbo / gpt-3.5-turbo


# ==================== 快速配置示例 ====================
#
# 🔹 示例1: 用智谱AI免费模型（最简配置，只需一行）
#    API_KEY=你的智谱Key
#
# 🔹 示例2: 用DeepSeek
#    API_KEY=你的DeepSeek_Key
#    API_BASE_URL=https://api.deepseek.com/v1
#    API_MODEL=deepseek-chat
#
# 🔹 示例3: 用Gemini
#    GEMINI_API_KEY=你的Gemini_Key
#
# 🔹 示例4: 用Claude
#    CLAUDE_API_KEY=你的Claude_Key
#
# 🔹 示例5: 自定义端口 + 智谱AI
#    PORT=8080
#    API_KEY=你的智谱Key



# ==================== AI 路由选择（统一入口 /api/ai） ====================
# 可选: openai（默认） / claude / gemini / responses
# AI_PROVIDER=openai

# 可选: 统一代理地址（留空表示不走代理）
# AI_PROXY_URL=http://127.0.0.1:7890

# OpenAI Responses 路由的推理等级（可选）
# 可选: low / medium / high / xhigh / none / auto
# OPENAI_REASONING_EFFORT=medium


# ==================== Embedding（RAG 向量） ====================
# EMBED_PROVIDER 可选: openai（默认） / gemini
# EMBED_PROVIDER=openai

# 如不填写 EMBED_BASE_URL / EMBED_MODEL，默认复用 API_BASE_URL 与 embedding-3
# EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EMBED_MODEL=embedding-3


# 在 https://tcb.cloud.tencent.com/ 创建环境后，
# 从控制台获取环境 ID 和 Publishable Key 填入：

# NEXT_PUBLIC_CLOUDBASE_ENV_ID=
# NEXT_PUBLIC_CLOUDBASE_REGION=ap-shanghai
# NEXT_PUBLIC_CLOUDBASE_ACCESS_KEY=
